{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"lint:fix": {
			"dependsOn": ["^lint:fix"]
		},
		"lint:fix:unsafe": {
			"dependsOn": ["^lint:fix:unsafe"]
		},
		"start": {
			"persistent": true
		},
		"test": {},
		"typecheck": {
			"dependsOn": ["^typecheck"]
		},
		"check:types": {
			"dependsOn": ["^check:types"]
		},
		"test:coverage": {
			"dependsOn": ["^test:coverage"],
			"outputs": ["coverage/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
