{
  "name": "tax-harvest",
  "version": "3.0.14",
  "private": true,
  "packageManager": "pnpm@9.14.2",
  "description": "Super cool risk app",
  "author": "Zachary Hansen",
  "license": "UNLICENSED",
  "homepage": "https://github.com/zacharyhansen/riska#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zacharyhansen/riska.git"
  },
  "bugs": {
    "url": "https://github.com/zacharyhansen/riska/issues"
  },
  "keywords": [
    "typescript",
    "nestjs",
    "template"
  ],
  "engines": {
    "node": ">=22.x",
    "pnpm": ">=9.x",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm",
    "bun": "please-use-pnpm"
  },
  "scripts": {
    "clean:install": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && rm -f pnpm-lock.yaml && pnpm install",
    "build": "turbo build",
    "dev": "turbo dev",
    "start": "turbo start",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "lint:file": "eslint",
    "typos": "chmod +x scripts/check_typos.sh && ./scripts/check_typos.sh",
    "test": "turbo test",
    "codegen": "turbo codegen",
    "ui": "pnpm --filter @repo/ui ui",
    "test:coverage": "turbo test:coverage",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky",
    "commit": "cz"
  },
  "dependencies": {
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.12.0",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@commitlint/types": "^19.5.0",
    "@eslint-react/eslint-plugin": "^1.48.5",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "@types/node": "^22.8.7",
    "@vitest/coverage-v8": "^3.1.2",
    "commitizen": "^4.3.0",
    "concurrently": "^9.0.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.24.0",
    "eslint-config-next": "15.3.1",
    "eslint-plugin-format": "^1.0.1",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "eslint-plugin-testing-library": "^6.3.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "turbo": "^2.1.2",
    "typescript": "5.4.2",
    "vitest": "^3.1.2",
    "vitest-mock-extended": "^3.1.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.3",
      "@types/react-dom": "19.1.3"
    }
  }
}
