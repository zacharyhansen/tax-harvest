// Its integral to understand that models in this file are global - i.e they are the sum of records
// across all tenants. All items in this schema represent configuration of a target schema and thus
// should hold no "data" of the actual customer. 

// Models that are config belong hee. A good rule of thumb is that if this the data should be shared 
// across or be easily copied from / to for environments then it can live here.

// !IMPORTANT: The web app should only ever access these models through views that are created in the specific schema
// the web app is using. Every table should contain a schema enum

model role {
  name                 String
  configuration_schema schema

  role_view           role_view[]
  component           component[]
  component_version   component_version[]
  published_component published_component[]
  user__foundation    user__foundation[]

  @@id([configuration_schema, name])
  @@schema("configuration")
}

enum view_type {
  product
  custom

  @@schema("configuration")
}

// Custom views of data in a schema
model view {
  /// Name of the view in the DB schema (v_<schema>__<tableName> or vc_<schema>__<customViewName>)
  name                 String
  type                 view_type
  configuration_schema schema
  /// name of the pg table in postgres this view references as the primary table (it PK is the PK of the view)
  pg_primary_table     String?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @default(now()) @updatedAt
  // postgrest properties
  pgt_deletable        Boolean
  pgt_description      String?
  pgt_insertable       Boolean
  pgt_is_view          Boolean
  pgt_updatable        Boolean
  pgt_pk_cols          String[]

  column        column[]
  role_column   role_column[]
  role_view     role_view[]
  link_source   link[]        @relation(name: "source")
  link_target   link[]        @relation(name: "target")
  link_junction link[]        @relation(name: "junction")

  @@id([configuration_schema, name])
  @@schema("configuration")
}

model column {
  /// Name of the column in the view
  name                 String
  configuration_schema schema
  created_at           DateTime               @default(now())
  updated_at           DateTime               @default(now()) @updatedAt
  view_name            String
  default_input_type   input_type
  // postgrest properties - for custom views we do our best to infer these
  pgt_default          String?
  pgt_description      String?
  pgt_enum             String[]
  pgt_max_len          Int?
  pgt_name             String?
  pgt_nominal_type     String?
  pgt_nullable         Boolean
  pgt_type             String
  // Inferred database attributes
  data_type            supported_pg_data_type
  is_pk                Boolean                @default(false)
  oid                  Int
  is_updatable         Boolean                @default(false)
  is_unique            Boolean                @default(false)
  /// name of the pg table in postgres this view column references
  pg_table             String?
  /// name of the pg column in postgres this view column references
  pg_column            String?
  /// The id of the view or table in the database that this column is from
  /// IMPORTANT: This is different than pg_table which is the root table if it exists
  table_id             Int
  /// The id of the column in the database from a view or table that this column is from
  /// IMPORTANT: This is different than pg_column which is the root column if it exists
  column_id            Int

  view                 view          @relation(fields: [configuration_schema, view_name], references: [configuration_schema, name], onDelete: Cascade)
  role_column          role_column[]
  link_source          link[]        @relation(name: "source")
  link_target          link[]        @relation(name: "target")
  link_junction_target link[]        @relation(name: "jc_target")
  link_junction_source link[]        @relation(name: "jc_source")

  @@id([configuration_schema, view_name, name])
  @@schema("configuration")
}

enum link_type {
  M2O
  O2M
  M2M
  O2O

  @@schema("configuration")
}

model link {
  id                          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type                        link_type
  configuration_schema        schema
  /// Name of the contrainst index (this is what pgsrt expect for hints)
  constraint                  String
  pgt_columns                 String[]
  source_view_name            String
  source_column_name          String
  target_view_name            String
  target_column_name          String
  // Meta data 
  pgt_is_self                 Boolean
  // fields if its M2M
  constraint_2                String?
  pgt_columns_2               String[]
  junction_view_name          String?
  junction_source_column_name String?
  junction_target_column_name String?
  // Configuration (not on role links)
  display_name                String

  view_source            view    @relation(name: "source", fields: [configuration_schema, source_view_name], references: [configuration_schema, name], onDelete: Cascade)
  view_target            view    @relation(name: "target", fields: [configuration_schema, target_view_name], references: [configuration_schema, name], onDelete: Cascade)
  column_target          column? @relation(name: "target", fields: [configuration_schema, target_view_name, target_column_name], references: [configuration_schema, view_name, name], onDelete: Cascade)
  column_source          column? @relation(name: "source", fields: [configuration_schema, source_view_name, source_column_name], references: [configuration_schema, view_name, name], onDelete: Cascade)
  junction_view          view?   @relation(name: "junction", fields: [configuration_schema, junction_view_name], references: [configuration_schema, name], onDelete: Cascade)
  junction_column_source column? @relation(name: "jc_source", fields: [configuration_schema, junction_view_name, junction_source_column_name], references: [configuration_schema, view_name, name], onDelete: Cascade)
  junction_column_target column? @relation(name: "jc_target", fields: [configuration_schema, junction_view_name, junction_target_column_name], references: [configuration_schema, view_name, name], onDelete: Cascade)

  @@unique([configuration_schema, source_view_name, source_column_name, target_view_name, target_column_name, junction_view_name])
  @@index([configuration_schema, source_view_name])
  @@schema("configuration")
}

model role_view {
  /// Name of the view in the DB schema (<view>__<role>)
  name                 String
  configuration_schema schema
  role_name            String
  /// Name of the view from data-tree.ts that this view is created from
  view_name            String
  // postgrest properties
  pgt_deletable        Boolean
  pgt_description      String?
  pgt_insertable       Boolean
  pgt_is_view          Boolean
  pgt_updatable        Boolean
  pgt_pk_cols          String[]

  view                       view                  @relation(fields: [configuration_schema, view_name], references: [configuration_schema, name], onDelete: Cascade)
  role                       role                  @relation(fields: [configuration_schema, role_name], references: [configuration_schema, name], onDelete: Restrict)
  role_column                role_column[]
  dataview                   dataview[]
  source_role_link           role_link[]           @relation(name: "source")
  target_role_link           role_link[]           @relation(name: "target")
  role_link                  role_link[]           @relation(name: "junction")
  dataset_link_filter_source dataset_link_filter[] @relation(name: "source_link_filter")
  dataset_link_filter_target dataset_link_filter[] @relation(name: "target_link_filter")

  @@id([configuration_schema, name])
  @@schema("configuration")
}

model role_column {
  name                 String
  configuration_schema schema
  role_view_name       String
  view_name            String

  role_view                 role_view         @relation(fields: [configuration_schema, role_view_name], references: [configuration_schema, name], onDelete: Cascade)
  column                    column            @relation(fields: [configuration_schema, view_name, name], references: [configuration_schema, view_name, name], onDelete: Cascade)
  view                      view              @relation(fields: [configuration_schema, view_name], references: [configuration_schema, name], onDelete: Cascade)
  dataview_column           dataview_column[]
  source_role_link          role_link[]       @relation(name: "source")
  target_role_link          role_link[]       @relation(name: "target")
  junction_source_role_link role_link[]       @relation(name: "jr_source")
  junction_target_role_link role_link[]       @relation(name: "jr_target")

  @@id([configuration_schema, role_view_name, name])
  @@schema("configuration")
}

// NOTE: we do not relate these back to root views (no need for now)
// and these links are there own real thing in the DB as it relates role views to each other
// this is basically a copy of the link table
model role_link {
  id                          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type                        link_type
  configuration_schema        schema
  /// Name of the contrainst index (this is what pgsrt expect for hints)
  constraint                  String
  pgt_columns                 String[]
  source_view_name            String
  source_column_name          String
  target_view_name            String
  target_column_name          String
  // Meta data 
  pgt_is_self                 Boolean
  // fields if its M2M
  constraint_2                String?
  pgt_columns_2               String[]
  junction_view_name          String?
  junction_source_column_name String?
  junction_target_column_name String?
  // Configuration (not on role links)
  display_name                String

  source_role_view       role_view    @relation(name: "source", fields: [configuration_schema, source_view_name], references: [configuration_schema, name], onDelete: Cascade)
  source_role_column     role_column  @relation(name: "source", fields: [configuration_schema, source_view_name, source_column_name], references: [configuration_schema, role_view_name, name], onDelete: Cascade)
  target_role_view       role_view    @relation(name: "target", fields: [configuration_schema, target_view_name], references: [configuration_schema, name], onDelete: Cascade)
  target_role_column     role_column  @relation(name: "target", fields: [configuration_schema, target_view_name, target_column_name], references: [configuration_schema, role_view_name, name], onDelete: Cascade)
  junction_role_view     role_view?   @relation(name: "junction", fields: [configuration_schema, junction_view_name], references: [configuration_schema, name], onDelete: Cascade)
  junction_column_source role_column? @relation(name: "jr_source", fields: [configuration_schema, junction_view_name, junction_source_column_name], references: [configuration_schema, role_view_name, name], onDelete: Cascade, map: "role_link_junction_source_column_fkey")
  junction_column_target role_column? @relation(name: "jr_target", fields: [configuration_schema, junction_view_name, junction_target_column_name], references: [configuration_schema, role_view_name, name], onDelete: Cascade, map: "role_link_junction_target_column_fkey")

  @@unique([configuration_schema, source_view_name, source_column_name, target_view_name, target_column_name, junction_view_name])
  @@index([configuration_schema, source_view_name])
  @@schema("configuration")
}

model dataset {
  id                   String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  configuration_schema schema
  cached               Json?   @db.JsonB
  dataview_id          String? @unique @db.Uuid
  query                String  @default("")

  dataset_link_filter dataset_link_filter[]
  dataview            dataview[]            @relation(name: "all")
  dataview_root       dataview?             @relation(name: "root", fields: [dataview_id], references: [id])
  form                form?
  table               table?

  @@index([configuration_schema, id])
  @@schema("configuration")
}

/// This is a many to many between role_link and dataset
model dataset_link_filter {
  dataset_id           String @db.Uuid
  source_view_name     String
  source_column_name   String
  target_view_name     String
  target_column_name   String
  configuration_schema schema
  dataview_column_id   String @db.Uuid
  /// Path of the field in the dataset tree (for nested filteres this will have something like vieew.column_name)
  path                 String

  dataset_column   dataview_column @relation(fields: [dataview_column_id], references: [id], onDelete: Cascade)
  dataset          dataset         @relation(fields: [dataset_id], references: [id], onDelete: Cascade)
  source_role_view role_view       @relation(name: "source_link_filter", fields: [source_view_name, configuration_schema], references: [name, configuration_schema], onDelete: Cascade)
  target_role_view role_view       @relation(name: "target_link_filter", fields: [target_view_name, configuration_schema], references: [name, configuration_schema], onDelete: Cascade)

  @@id([dataset_id, source_view_name, source_column_name, target_view_name, target_column_name])
  @@index([dataset_id])
  @@schema("configuration")
}

model dataview {
  id                   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  configuration_schema schema
  dataset_id           String @db.Uuid
  role_view_name       String
  constraint           String

  dataview_column dataview_column[] @relation(name: "dataview_having_columns")
  dataset         dataset           @relation(name: "all", fields: [dataset_id], references: [id], onDelete: Cascade)
  dataset_root    dataset?          @relation(name: "root")
  role_view       role_view         @relation(fields: [configuration_schema, role_view_name], references: [configuration_schema, name], onDelete: Cascade)
  parent_column   dataview_column?  @relation(name: "column_having_dataview")

  @@index([dataset_id])
  @@schema("configuration")
}

model dataview_column {
  id                   String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  configuration_schema schema
  parent_dataview_id   String     @db.Uuid
  role_view_name       String
  role_column_name     String
  /// It will equal another dataview id if the column is referencing a relation
  child_dataview_id    String?    @unique @db.Uuid
  // Shared component attributes
  label                String?
  input_type           input_type @default(text)
  description          String?
  header_group         String?
  // Table Attributes
  ag_width             Int        @default(200)
  ag_min_width         Int        @default(50)
  ag_flex              Int?
  ag_editable          Boolean    @default(false)
  ag_resizable         Boolean    @default(true)
  ag_pinned            ag_pinned?
  order                Int        @default(0)
  hidden               Boolean    @default(false)
  // Form Attributes

  parent_dataview     dataview              @relation(name: "dataview_having_columns", fields: [parent_dataview_id], references: [id], onDelete: Cascade)
  child_dataview      dataview?             @relation(name: "column_having_dataview", fields: [child_dataview_id], references: [id], onDelete: Cascade)
  role_column         role_column           @relation(fields: [configuration_schema, role_view_name, role_column_name], references: [configuration_schema, role_view_name, name], onDelete: Cascade)
  dataset_link_filter dataset_link_filter[]

  // Only one column per dataview of the column name unless you add in child_dataview_id
  @@unique([parent_dataview_id, role_column_name, child_dataview_id])
  @@index([parent_dataview_id])
  @@schema("configuration")
}

enum input_type {
  // direct
  text
  phone
  password
  textarea
  number
  percentage
  usd
  combobox
  combobox_multi
  date
  timestamp
  checkbox
  switch
  tiptap
  slider
  // advanced
  user

  @@schema("configuration")
}

enum ag_pinned {
  left
  right

  @@schema("configuration")
}

enum supported_pg_data_type {
  unknown

  array_integer
  array_json
  array_jsonb
  array_text
  array_boolean
  array_numeric
  array_varchar
  array_date
  array_timestamp
  bigint
  bigserial
  bit
  bit_varying
  boolean
  box
  bytea
  character
  character_varying
  cidr
  circle
  date
  double_precision
  enum
  float4
  float8
  inet
  integer
  interval
  json
  jsonb
  line
  lseg
  macaddr
  money
  numeric
  path
  point
  polygon
  real
  serial
  smallint
  smallserial
  text
  time
  time_with_time_zone
  timestamp
  timestamp_with_time_zone
  timestamp_without_time_zone
  tsquery
  tsvector
  txid_snapshot
  uuid
  xml

  @@schema("configuration")
}

// Layout represents the overall container
model layout {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                 String   @db.VarChar(100)
  configuration_schema schema
  label                String?
  description          String?
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now()) @updatedAt
  rows                 Int      @default(12) // Total number of rows in the grid
  columns              Int      @default(12) // Total number of columns in the grid

  tile              tile[]
  component_version component_version?

  @@schema("configuration")
}

// Tile represents a draggable container that can hold widgets
model tile {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  configuration_schema schema
  layout_id            String   @db.Uuid
  grid_start           Int      @default(0) // Grid column start position
  grid_end             Int      @default(12) // Grid row start position
  width                Int      @default(12) // Number of grid columns the tile spans
  height               Int      @default(4) // Number of grid rows the tile spans
  order                Int      @default(1)
  label                String?
  description          String?
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now()) @updatedAt
  default_open         Boolean  @default(true)

  layout  layout   @relation(fields: [layout_id], references: [id], onDelete: Cascade)
  widgets widget[]

  @@index([layout_id])
  @@schema("configuration")
}

model widget {
  id                   String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  configuration_schema schema
  tile_id              String  @db.Uuid
  label                String
  description          String?
  order                Int     @default(1)

  tile                          tile                            @relation(fields: [tile_id], references: [id], onDelete: Cascade)
  published_component_on_widget published_component_on_widget[]

  @@index([tile_id])
  @@schema("configuration")
}

model published_component_on_widget {
  id                     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  configuration_schema   schema
  widget_id              String @db.Uuid
  published_component_id String @db.Uuid
  order                  Int    @default(1)

  widget              widget              @relation(fields: [widget_id], references: [id], onDelete: Cascade)
  published_component published_component @relation(fields: [published_component_id], references: [id], onDelete: Cascade)

  @@index([widget_id])
  @@schema("configuration")
}

enum component_type {
  form
  table
  layout

  @@schema("configuration")
}

model component {
  id                   String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  configuration_schema schema
  type                 component_type
  label                String
  created_at           DateTime       @default(now())
  updated_at           DateTime       @default(now()) @updatedAt
  description          String?
  created_by_id        String
  role_name            String

  role                role                  @relation(fields: [configuration_schema, role_name], references: [configuration_schema, name], onDelete: Cascade)
  component_version   component_version[]
  published_component published_component[]
  created_by          auth_user             @relation(fields: [created_by_id], references: [clerk_id], onDelete: Restrict)

  @@schema("configuration")
}

model component_version {
  configuration_schema schema
  version              Int
  type                 component_type
  component_id         String         @db.Uuid
  created_at           DateTime       @default(now())
  updated_at           DateTime       @default(now()) @updatedAt
  created_by_id        String
  role_name            String
  /// Used for deterministicly named components (i.e. layouts - FE can always look for specific slug)
  slug                 String?
  // Component options
  form_id              String?        @unique @db.Uuid
  table_id             String?        @unique @db.Uuid
  layout_id            String?        @unique @db.Uuid

  role                role                  @relation(fields: [configuration_schema, role_name], references: [configuration_schema, name], onDelete: Cascade)
  form                form?                 @relation(fields: [form_id], references: [id], onDelete: Cascade)
  table               table?                @relation(fields: [table_id], references: [id], onDelete: Cascade)
  layout              layout?               @relation(fields: [layout_id], references: [id], onDelete: Cascade)
  published_component published_component[]
  component           component             @relation(fields: [component_id], references: [id], onDelete: Cascade)
  created_by          auth_user             @relation(fields: [created_by_id], references: [clerk_id], onDelete: Restrict)

  @@id([component_id, version])
  @@unique([slug, version, role_name])
  @@schema("configuration")
}

model published_component {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  configuration_schema schema
  environment_schema   schema
  component_id         String    @db.Uuid
  version              Int
  published_at         DateTime?
  published_by_id      String?
  role_name            String
  /// Used for deterministicly named components (i.e. layouts - FE can always look for specific slug)
  slug                 String?

  role                          role                            @relation(fields: [configuration_schema, role_name], references: [configuration_schema, name], onDelete: Cascade)
  environment                   environment                     @relation(fields: [environment_schema], references: [schema], onDelete: Cascade)
  component                     component                       @relation(fields: [component_id], references: [id], onDelete: Cascade)
  component_version             component_version               @relation(fields: [component_id, version], references: [component_id, version], onDelete: Cascade)
  published_by                  auth_user?                      @relation(fields: [published_by_id], references: [clerk_id], onDelete: Restrict)
  published_component_on_widget published_component_on_widget[]

  @@unique([environment_schema, component_id]) // only one version published at a time in an environment
  @@unique([environment_schema, role_name, slug]) // only one slug published at a time in an environment
  @@index([environment_schema, role_name, slug])
  @@schema("configuration")
}

model form {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  configuration_schema schema
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now()) @updatedAt
  dataset_id           String   @unique @db.Uuid
  form_section_id      String?  @unique @db.Uuid
  columns              Int      @default(1)

  form_instance     form_instance[]
  form_section_all  form_section[]     @relation(name: "all")
  form_section      form_section?      @relation(name: "root", fields: [form_section_id], references: [id], onDelete: SetNull)
  field             field[]
  dataset           dataset            @relation(fields: [dataset_id], references: [id], onDelete: Cascade)
  component_version component_version?

  @@schema("configuration")
}

model form_section {
  id                   String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  configuration_schema schema
  order                Int     @default(1)
  form_id              String  @db.Uuid
  label                String?
  description          String?
  is_repeated          Boolean @default(false)
  border               Boolean @default(true)
  columns              Int     @default(1)
  parent_section_id    String? @db.Uuid

  form           form           @relation(name: "all", fields: [form_id], references: [id], onDelete: Cascade)
  form_root      form?          @relation(name: "root")
  child_section  form_section[] @relation(name: "parent")
  parent_section form_section?  @relation(name: "parent", fields: [parent_section_id], references: [id], onDelete: Cascade)
  field          field[]

  @@index([form_id])
  @@schema("configuration")
}

model field {
  configuration_schema schema
  name                 String
  created_at           DateTime   @default(now())
  updated_at           DateTime   @default(now()) @updatedAt
  required             Boolean    @default(true)
  input_type           input_type
  name_locked          Boolean    @default(false)
  label                String?
  description          String?
  placeholder          String?
  default_value        String?
  options              Json       @default("[]")
  // relations
  section_id           String     @db.Uuid
  form_id              String     @db.Uuid

  form    form         @relation(fields: [form_id], references: [id], onDelete: Cascade)
  section form_section @relation(fields: [section_id], references: [id], onDelete: Cascade)

  @@id([form_id, name])
  @@index([form_id])
  @@schema("configuration")
}

model form_instance {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  configuration_schema schema
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now()) @updatedAt
  content              String   @default("")
  /// Should be follow the react hook form api for values of a form
  values               Json     @default("{}")
  // relations
  form_id              String   @db.Uuid
  created_by_id        String

  created_by auth_user @relation(fields: [created_by_id], references: [clerk_id], onDelete: Restrict)
  form       form      @relation(fields: [form_id], references: [id], onDelete: Restrict)

  @@index([form_id])
  @@schema("configuration")
}

model table {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  configuration_schema schema
  updated_at           DateTime @default(now()) @updatedAt
  created_at           DateTime @default(now())
  dataset_id           String   @unique @db.Uuid

  dataset           dataset            @relation(fields: [dataset_id], references: [id], onDelete: Cascade)
  component_version component_version?

  @@schema("configuration")
}
