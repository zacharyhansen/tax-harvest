generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"] // Enable the postgresqlExtensions. Currently in preview
}

generator nestgraphql {
  provider                        = "prisma-nestjs-graphql"
  output                          = "../src/generated/graphql"
  emitSingle                      = true
  graphqlScalars_BigInt_name      = "GraphQLBigInt"
  graphqlScalars_BigInt_specifier = "graphql-scalars"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model User {
  /// This is the clerk user id
  id                 String   @id
  /// Stripe user id
  stripeCustomerId   String   @unique
  // Plaid User uid
  plaidCustomerId    String?
  plaidUserToken     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt
  email              String?
  phoneNumber        String?
  /// @HideField({ output: true, input: true })  
  hashedRefreshToken String?
  name               String?
  photo              String?

  Portfolio         Portfolio[]
  Account           Account[]
  UsersOnPortfolios UsersOnPortfolios[]
  favorites         Asset[]
  authConnections   AuthConnection[]
  Harvest           Harvest[]
}

enum PlaidLinkStatus {
  /// Portfolio needs a plaid link
  NONE
  /// We have created the link in plaid and are waiting for the SESSION_FINISHED webhook 
  CREATED
  /// We recieved the webhook link data - now we are downloading/syncing data for the accounts
  SESSION_FINISHED
  /// Data for the link/accoutns ahs been downloaded
  SYNCED
}

enum HarvestNotificationFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  NEVER
}

model Portfolio {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt
  createdById       String
  name              String   @default("Main")
  /// How often should we harvest for the portfolio
  harvestCycleWeeks Int      @default(4)

  /// Minimum p and l for a lot to be considered harvestable
  minimumLotPAndL                     Decimal                      @default(10) @db.Decimal(14, 2)
  // Harvest Fields
  /// How much $ amount does a single share need to exceed to be a valid harvest share (i.e. shares with a p/l lower we shouldnt even care about)
  harvestShareDollarThreshold         Decimal                      @default(".01") @db.Decimal(14, 2)
  /// As we iterate through different tickets to build a harvest, how much $ should we target before moving to the next one
  harvestTickerBucketDollarSizeLong   Decimal                      @default(1500) @db.Decimal(14, 2)
  /// How much is a valid bucket (otherwise a ticker is considered 'slop')
  harvestTickerBucketLowerLimitLong   Decimal                      @default(".01") @db.Decimal(14, 2)
  /// As we iterate through different tickets to build a harvest, how much $ should we target before moving to the next one
  harvestTickerBucketDollarSizeShort  Decimal                      @default(1000) @db.Decimal(14, 2)
  /// How much is a valid bucket (otherwise a ticker is considered 'slop')
  harvestTickerBucketLowerLimitShort  Decimal                      @default(".01") @db.Decimal(14, 2)
  // notification settings
  notificationFrequency               HarvestNotificationFrequency @default(WEEKLY)
  endOfYearTaxOpportunityNotification Boolean                      @default(true)

  accounts                    Account[]
  usersOnPortfolios           UsersOnPortfolios[]
  createdBy                   User                          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  authConnections             AuthConnection[]
  harvests                    Harvest[]
  log                         Log[]
  assetMerge                  AssetMerge[]
  lotChange                   LotChange[]
  harvestTransaction          HarvestTransaction[]
  files                       File[]
  lots                        Lot[]
  positions                   Position[]
  transactions                Transaction[]
  realizedPAndL               RealizedPAndL[]
  harvestTransactionItem      HarvestTransactionItem[]
  notification                Notification[]
  mergeError                  MergeError[]
  portfolioBalanceSnapshot    PortfolioBalanceSnapshot[]
  plaidMerge                  PlaidMerge[]
  transactionOnAssetMerge     TransactionOnAssetMerge[]
  lotChangeList               LotChangeList[]
  accountRealizedPAndLHistory AccountRealizedPAndLHistory[]
  lotUpload                   LotUpload[]
  lotUploadFile               LotUploadFile[]
  positionSnapshot            PositionSnapshot[]
  porfolioConnect             PortfolioConnect[]
}

enum PorfolioConnectState {
  PENDING
  COMPLETED
  ERROR
}

/// The connect onbaording flow that is initiated by the user for a specific institution. This is controlled by the xstate machine
model PortfolioConnect {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  portfolioId        String               @db.Uuid
  createdAt          DateTime             @default(now())
  persistedSnapshot  Json                 @default("{}") @db.JsonB
  authConnectionId   String?              @unique @db.Uuid
  plaidInstitutionId String
  updatedAt          DateTime             @default(now()) @updatedAt
  state              PorfolioConnectState @default(PENDING)

  authConnection   AuthConnection?
  portfolio        Portfolio        @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  account          Account[]
  plaidInstitution PlaidInstitution @relation(fields: [plaidInstitutionId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, plaidInstitutionId])
  @@index([portfolioId, state])
}

enum HarvestType {
  SELL
  REDUCE_COST_BASIS
  REDUCE_TAXES
  CAPTURE_GAINS_TAX_FREE
  NO_OPPORTUNITY_GAINS
  NO_OPPORTUNITY_LOSSES
  NO_OPPORTUNITY_EMPTY
}

enum HarvestStep {
  CONFIGURE
  REVIEW
  COMPLETE
}

model Harvest {
  id                        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @default(now()) @updatedAt
  label                     String
  createdById               String
  portfolioId               String      @db.Uuid
  amount                    Decimal     @db.Decimal(14, 4)
  date                      DateTime    @default(now())
  type                      HarvestType
  step                      HarvestStep @default(CONFIGURE)
  /// Date to revert is possible after wash period - its the date of the revert if revert is true and notify is noify is true
  afterWashRevertDate       DateTime    @default(now())
  /// Date to lock in the recommendation 
  recommendationExpiresDate DateTime    @default(now())
  /// should notify be performed
  notify                    Boolean     @default(true)

  createdBy               User                     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  portfolio               Portfolio                @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  harvestTransactions     HarvestTransaction[]
  harvestTransactionItems HarvestTransactionItem[]

  @@index([portfolioId, afterWashRevertDate])
}

/// Represent the logical unit of a harvest transaction whose entry point is a sale of a security. It can possibly have a replacement buy and then a revert after the wash sale window for the sale / sale + buy
model HarvestTransaction {
  id                                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt                          DateTime @default(now())
  updatedAt                          DateTime @default(now()) @updatedAt
  harvestId                          String   @db.Uuid
  portfolioId                        String   @db.Uuid
  /// Is this transaction part of counter group of transactions for harvest (i.e. selling a gain to counter the loss that was selected)
  counterTransaction                 Boolean  @default(false)
  /// should revert transactions be performed
  revert                             Boolean  @default(true)
  harvestTransactionItemId           String   @unique @db.Uuid
  replacementTransactionItemId       String?  @unique @db.Uuid
  revertHarvestTransactionItemId     String?  @unique @db.Uuid
  revertReplacementTransactionItemId String?  @unique @db.Uuid

  portfolio                        Portfolio               @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  harvest                          Harvest                 @relation(fields: [harvestId], references: [id], onDelete: Cascade)
  harvestTransactionItem           HarvestTransactionItem  @relation(name: "harvestTransaction", fields: [harvestTransactionItemId], references: [id], onDelete: Restrict)
  replacementTransactionItem       HarvestTransactionItem? @relation(name: "replacementTransaction", fields: [replacementTransactionItemId], references: [id], onDelete: SetNull)
  revertHarvestTransactionItem     HarvestTransactionItem? @relation(name: "revertHarvestTransaction", fields: [revertHarvestTransactionItemId], references: [id], onDelete: Restrict)
  revertReplacementTransactionItem HarvestTransactionItem? @relation(name: "revertReplacementTransaction", fields: [revertReplacementTransactionItemId], references: [id], onDelete: SetNull)

  @@index([portfolioId])
  @@index([harvestId])
}

model HarvestTransactionItem {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  portfolioId       String    @db.Uuid
  harvestId         String    @db.Uuid
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt
  orderType         OrderType
  assetSymbol       String
  /// The date of the harvest transtion item is assumed to be executed
  date              DateTime  @default(now())
  completedDate     DateTime?
  quantity          Decimal   @db.Decimal(14, 4)
  price             Decimal   @db.Decimal(14, 4)
  // lot fields
  lotId             String?   @db.Uuid
  lotAcquiredDate   DateTime
  lotPricePaid      Decimal   @db.Decimal(14, 4)
  lotPriceAtHarvest Decimal   @db.Decimal(14, 4)

  harvest                      Harvest             @relation(fields: [harvestId], references: [id], onDelete: Cascade)
  portfolio                    Portfolio           @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset                        Asset               @relation(fields: [assetSymbol], references: [symbol], onDelete: Restrict)
  lotSold                      Lot?                @relation(fields: [lotId], references: [id], onDelete: SetNull)
  harvestTransaction           HarvestTransaction? @relation(name: "harvestTransaction")
  replacementTransaction       HarvestTransaction? @relation(name: "replacementTransaction")
  revertHarvestTransaction     HarvestTransaction? @relation(name: "revertHarvestTransaction")
  revertReplacementTransaction HarvestTransaction? @relation(name: "revertReplacementTransaction")

  @@index([lotId])
}

// Account ------------------------------------------------------------------------------------------------------------------------------
/// Unless unconnected, these are always plaid accounts
model Account {
  /// Internal account identifier
  id                   String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @default(now()) @updatedAt
  portfolioConnectId   String                       @db.Uuid
  /// External provider of the account - null if its an system generated account
  provider             AccountProvider              @default(UNCONNECTED)
  // External provider of the account for lot uploads / lot identification / etc.
  supportedLotProvider SupportedAccountLotProvider? @default(ETRADE)
  /// The auth connection the account has been provided from 
  authConnectionId     String?                      @db.Uuid
  /// The unique id in the external system for the account
  externalId           String?
  name                 String?
  plaidAccountMask     String?
  key                  String?
  /// Who created the model
  createdById          String
  /// The description of the account
  description          String?
  /// The type of account
  type                 String                       @default("Unconnected")
  subType              String?
  /// The mode of the account
  mode                 AccountMode?
  /// Is this account archived
  status               AccountStatus                @default(ACTIVE)
  /// Which portfolio does this account belong to
  /// @HideField({ match: '@(Account)Create*Input' })
  portfolioId          String                       @db.Uuid
  /// If the account was closed
  closedDate           DateTime?
  /// Option level for the account
  optionLevel          OptionLevel?
  /// The date the account was seeded with lots using a CSV or other import - transactions after this date will be applied using our algorithim
  lotSeededDate        DateTime?

  // Setup fields
  uploadedPositions Boolean @default(false)
  setRealizedValues Boolean @default(false)
  skipSetup         Boolean @default(false)

  // Browserless io fields
  liveURL        String?
  liveURLCreated DateTime?

  // Plaid account info
  current   Decimal @default(0) @db.Decimal(14, 4)
  available Decimal @default(0) @db.Decimal(14, 4)

  // All of this is likely legacy - we should consider removing these since we are not connecting to etrade directly 
  // Balance fields
  cashForOpenOrders                Decimal? @db.Decimal(14, 4)
  balanceMoneyMarket               Decimal? @db.Decimal(14, 4)
  // Computed
  accountValueTotal                Decimal? @db.Decimal(14, 4)
  marketValueTotal                 Decimal? @db.Decimal(14, 4)
  cashAvailableForInvestment       Decimal? @db.Decimal(14, 4)
  cashNet                          Decimal? @db.Decimal(14, 4)
  cashBalance                      Decimal? @db.Decimal(14, 4)
  cashSettledForInvestment         Decimal? @db.Decimal(14, 4)
  cashUnsettledForInvestment       Decimal? @db.Decimal(14, 4)
  cashBuyingPower                  Decimal? @db.Decimal(14, 4)
  fundsWithheldFromPurchasingPower Decimal? @db.Decimal(14, 4)
  fundsWithheldFromWithdrawal      Decimal? @db.Decimal(14, 4)
  marginBuyingPower                Decimal? @db.Decimal(14, 4)
  marginBuyingPowerDT              Decimal? @db.Decimal(14, 4)
  balanceShortAdjustment           Decimal? @db.Decimal(14, 4)
  balanceAccount                   Decimal? @db.Decimal(14, 4)
  equityRegt                       Decimal? @db.Decimal(14, 4)
  equityRegtPercent                Decimal? @db.Decimal(14, 4)
  cashOpenOrderReserveDT           Decimal? @db.Decimal(14, 4)
  marginOpenOrderReserveDT         Decimal? @db.Decimal(14, 4)
  raw                              Json?

  /// @HideField({ match: '@(Account)Create*Input' })
  createdBy                   User                          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  authConnection              AuthConnection?               @relation(fields: [authConnectionId], references: [id], onDelete: Cascade)
  portfolio                   Portfolio                     @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  positions                   Position[]
  transactions                Transaction[]
  realizedPAndL               RealizedPAndL[]
  lots                        Lot[]
  files                       File[]
  assetMerge                  AssetMerge[]
  notification                Notification[]
  plaidMerge                  PlaidMerge[]
  lotChange                   LotChange[]
  transactionOnAssetMerge     TransactionOnAssetMerge[]
  mergeError                  MergeError[]
  lotChangeList               LotChangeList[]
  accountRealizedPAndLHistory AccountRealizedPAndLHistory[]
  lotUpload                   LotUpload[]
  lotUploadFile               LotUploadFile[]
  portfolioConnect            PortfolioConnect              @relation(fields: [portfolioConnectId], references: [id], onDelete: Cascade)

  /// This attempts to ensure user doesnt link the same account twice (i.e. same plaid account mask)
  @@unique([authConnectionId, plaidAccountMask, type])
  @@index([authConnectionId])
  @@index([portfolioId])
}

enum ProfitAndLossType {
  SHORT_TERM_CAPITAL_GAIN
  LONG_TERM_CAPITAL_GAIN
  DIVIDEND
  QUALIFIED_DIVIDEND
  NON_QUALIFIED_DIVIDEND
  DIVIDEND_REINVESTMENT
  INTEREST
  INTEREST_REINVESTMENT
  DISTRIBUTION
  ACCOUNT_FEE
  MANAGEMENT_FEE
  FUND_FEE
  TAX_WITHHELD
  NON_RESIDENT_TAX
  DEPOSIT
  WITHDRAWAL
  CONTRIBUTION
  RETURN_OF_PRINCIPAL
  LOAN_PAYMENT
  MARGIN_EXPENSE
  STOCK_DISTRIBUTION
  UNQUALIFIED_GAIN
}

model RealizedPAndL {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt          DateTime @default(now())
  accountId          String   @db.Uuid
  portfolioId        String   @db.Uuid
  /// The positions at the point and time of the realized p&l - this can be null if the acocunt is created before we have connected to plaid
  positionSnapshotId String?  @db.Uuid

  // Fields controlled by the plaid/investments/holdings/get https://plaid.com/docs/api/products/investments/#investmentsholdingsget
  current             Decimal   @default(0) @db.Decimal(14, 4)
  available           Decimal   @default(0) @db.Decimal(14, 4)
  lastUpdatedDatetime DateTime?

  // Fields we track (1 to 1 with ProfitAndLossType) using plaid/investments/transactions/get https://plaid.com/docs/api/products/investments/#investmentstransactionsget
  shortTermCapitalGain Decimal @default(0) @db.Decimal(14, 4)
  longTermCapitalGain  Decimal @default(0) @db.Decimal(14, 4)
  dividend             Decimal @default(0) @db.Decimal(14, 4)
  qualifiedDividend    Decimal @default(0) @db.Decimal(14, 4)
  nonQualifiedDividend Decimal @default(0) @db.Decimal(14, 4)
  dividendReinvestment Decimal @default(0) @db.Decimal(14, 4)
  interest             Decimal @default(0) @db.Decimal(14, 4)
  interestReinvestment Decimal @default(0) @db.Decimal(14, 4)
  distribution         Decimal @default(0) @db.Decimal(14, 4)
  accountFee           Decimal @default(0) @db.Decimal(14, 4)
  managementFee        Decimal @default(0) @db.Decimal(14, 4)
  fundFee              Decimal @default(0) @db.Decimal(14, 4)
  taxWithheld          Decimal @default(0) @db.Decimal(14, 4)
  nonResidentTax       Decimal @default(0) @db.Decimal(14, 4)
  deposit              Decimal @default(0) @db.Decimal(14, 4)
  withdrawal           Decimal @default(0) @db.Decimal(14, 4)
  contribution         Decimal @default(0) @db.Decimal(14, 4)
  returnOfPrincipal    Decimal @default(0) @db.Decimal(14, 4)
  loanPayment          Decimal @default(0) @db.Decimal(14, 4)
  marginExpense        Decimal @default(0) @db.Decimal(14, 4)
  stockDistribution    Decimal @default(0) @db.Decimal(14, 4)
  unqualifiedGain      Decimal @default(0) @db.Decimal(14, 4)

  // Derived info we roll up for efficiency
  unrealizedProfit Decimal @default(0) @db.Decimal(14, 4)
  unrealizedLoss   Decimal @default(0) @db.Decimal(14, 4)

  positionSnapshot            PositionSnapshot?             @relation(fields: [positionSnapshotId], references: [id], onDelete: Cascade)
  portfolio                   Portfolio                     @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  account                     Account                       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountRealizedPAndLHistory AccountRealizedPAndLHistory[]

  @@index([accountId, createdAt(sort: Desc)])
}

// This tracks the result of processing a single lot change or a non lot plaid transaction
model AccountRealizedPAndLHistory {
  id                BigInt            @id @default(autoincrement())
  uuid              String            @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @default(now()) @updatedAt
  accountId         String            @db.Uuid
  /// This will be null if we have not created a new P and L with this transaction included yet (means it still needs to be applied)
  realizedPAndLId   String?           @db.Uuid
  portfolioId       String            @db.Uuid
  profitAndLossType ProfitAndLossType
  value             Decimal           @default(0) @db.Decimal(14, 4)
  plaidMergeId      String            @db.Uuid
  // One of the two will be set
  lotChangeListId   String?           @db.Uuid
  transactionId     String?           @db.Uuid

  plaidMerge    PlaidMerge     @relation(fields: [plaidMergeId], references: [id], onDelete: Cascade)
  realizedPAndL RealizedPAndL? @relation(fields: [realizedPAndLId], references: [id], onDelete: Cascade)
  account       Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  portfolio     Portfolio      @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  lotChangeList LotChangeList? @relation(fields: [lotChangeListId], references: [id], onDelete: SetNull)
  transaction   Transaction?   @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([accountId, realizedPAndLId])
}

model Transaction {
  /// Internal transaction identifier
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @default(now()) @updatedAt
  /// PLaid investment_transaction_id
  externalId         String             @unique
  accountId          String             @db.Uuid
  securityType       String?
  type               String?
  subtype            String?
  transactionDate    DateTime?
  postDate           DateTime?
  settlementDate     DateTime?
  description        String?
  datailsURI         String?
  memo               String?
  assetSymbol        String
  quantity           Decimal?           @db.Decimal(14, 4)
  price              Decimal?           @db.Decimal(14, 4)
  amount             Decimal?           @db.Decimal(14, 4)
  settlementCurrency String?
  paymentCurrency    String?
  fee                Decimal?           @db.Decimal(14, 4)
  displaySymbol      String?
  detailsURI         String?
  merged             Boolean            @default(false)
  portfolioId        String             @db.Uuid
  /// This being null should me either we havent applied it yet or we were unable to apply it (essentially an error in transaction categorization)
  profitAndLossType  ProfitAndLossType?

  portfolio                   Portfolio                     @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset                       Asset                         @relation(fields: [assetSymbol], references: [symbol], onDelete: Restrict)
  account                     Account                       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactionOnAssetMerge     TransactionOnAssetMerge[]
  accountRealizedPAndLHistory AccountRealizedPAndLHistory[]

  @@unique([accountId, externalId])
}

model PlaidMerge {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
  accountId        String   @db.Uuid
  portfolioId      String   @db.Uuid
  resolveLotsInput Json     @db.JsonB

  account                     Account                       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  portfolio                   Portfolio                     @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  assetMerge                  AssetMerge[]
  AccountRealizedPAndLHistory AccountRealizedPAndLHistory[]
}

model AssetMerge {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt
  accountId          String   @db.Uuid
  portfolioId        String   @db.Uuid
  plaidMergeId       String   @db.Uuid
  assetSymbol        String
  logTrxMergeId      BigInt?  @db.BigInt
  targetValue        Decimal? @db.Decimal(14, 4)
  targetQuantity     Decimal? @db.Decimal(14, 4)
  /// Will be null for sells of entire assets where plaid does nto return a position
  positionSnapshotId String?  @db.Uuid
  mergeErrorId       String?  @db.Uuid
  lotData            Json     @db.JsonB
  resolvedLotChange  Json     @db.JsonB
  error              Json?    @db.JsonB

  mergeError              MergeError?               @relation(fields: [mergeErrorId], references: [id], onDelete: Cascade)
  account                 Account                   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  portfolio               Portfolio                 @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  logTrxMerge             Log?                      @relation(fields: [logTrxMergeId], references: [id], onDelete: SetNull)
  plaidMerge              PlaidMerge?               @relation(fields: [plaidMergeId], references: [id], onDelete: Cascade)
  asset                   Asset                     @relation(fields: [assetSymbol], references: [symbol], onDelete: Restrict)
  transactionOnAssetMerge TransactionOnAssetMerge[]
  lotChangeList           LotChangeList[]
  positionSnapshot        PositionSnapshot?         @relation(fields: [positionSnapshotId], references: [id], onDelete: Cascade)

  @@index([portfolioId, createdAt(sort: Desc)])
}

model TransactionOnAssetMerge {
  assetMergeId  String @db.Uuid
  transactionId String @db.Uuid
  portfolioId   String @db.Uuid
  accountId     String @db.Uuid

  assetMerge  AssetMerge  @relation(fields: [assetMergeId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  portfolio   Portfolio   @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([assetMergeId, transactionId])
}

model LotChangeList {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetMergeId       String   @db.Uuid
  portfolioId        String   @db.Uuid
  accountId          String   @db.Uuid
  usedByAssetMergeId String?  @unique @db.Uuid
  /// Were the changes from this list chosen to be applied to the account?
  appliedToAccount   Boolean?

  portfolio                   Portfolio                     @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  account                     Account                       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  assetMerge                  AssetMerge                    @relation(fields: [assetMergeId], references: [id], onDelete: Cascade)
  LotChange                   LotChange[]
  AccountRealizedPAndLHistory AccountRealizedPAndLHistory[]

  @@unique([assetMergeId, appliedToAccount]) // Only one of the lot changes of the asset merge can be applied to the account
}

model LotChange {
  id                             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  portfolioId                    String        @db.Uuid
  accountId                      String        @db.Uuid
  lotId                          String        @db.Uuid
  aquiredDate                    DateTime
  quantityFinal                  Decimal       @db.Decimal(14, 4)
  quantityChange                 Decimal       @db.Decimal(14, 4)
  price                          Decimal       @db.Decimal(14, 4)
  assetSymbol                    String
  upsert                         Json          @db.JsonB
  operationType                  OperationType
  lotChangeListId                String?       @db.Uuid
  realizedProfitAndLossShortTerm Decimal       @default(0) @db.Decimal(14, 4)
  realizedProfitAndLossLongTerm  Decimal       @default(0) @db.Decimal(14, 4)

  lotChangeList LotChangeList? @relation(fields: [lotChangeListId], references: [id], onDelete: Cascade)
  lot           Lot            @relation(fields: [lotId], references: [id], onDelete: Cascade)
  portfolio     Portfolio      @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  account       Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([lotChangeListId])
}

enum OperationType {
  upsert
  delete
  create
  update
}

/// Point in time data from plaid auth connection for positions
model PositionSnapshot {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt        DateTime @default(now())
  portfolioId      String   @db.Uuid
  authConnectionId String   @db.Uuid

  authConnection                             AuthConnection                               @relation(fields: [authConnectionId], references: [id], onDelete: Cascade)
  portfolio                                  Portfolio                                    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  position                                   Position[]
  assetMerge                                 AssetMerge[]
  realizedPAndL                              RealizedPAndL[]
  PositionSnapshotOnPortfolioBalanceSnapshot PositionSnapshotOnPortfolioBalanceSnapshot[]

  @@index([portfolioId, createdAt(sort: Desc)])
}

/// This model really should never be shown to the user - most api's have it but its
/// just a grouping of open lots. We track it as its needed for calculations derived from plaid 
/// but user facing tables etc. and harvest calc's should roll up lots 
model Position {
  id                 BigInt    @id @default(autoincrement())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt
  positionSnapshotId String    @db.Uuid
  accountId          String    @db.Uuid
  portfolioId        String    @db.Uuid
  /// The unique id in the external system for the position
  externalId         String?
  dateAcquired       DateTime?
  dateExpiration     DateTime?
  assetSymbol        String
  pricePaid          Decimal?  @db.Decimal(14, 4)
  quantity           Decimal   @db.Decimal(14, 4)
  type               String?

  commissionTotal Decimal? @db.Decimal(14, 4)
  feesOther       Decimal? @db.Decimal(14, 4)
  feesDay         Decimal? @db.Decimal(14, 4)
  gainDay         Decimal? @db.Decimal(14, 4)
  marketValue     Decimal? @db.Decimal(14, 4)
  costTotal       Decimal? @db.Decimal(14, 4)
  gainTotal       Decimal? @db.Decimal(14, 4)
  gainTotalPCT    Decimal? @db.Decimal(14, 4)
  costPerShare    Decimal? @db.Decimal(14, 4)
  commissionDay   Decimal? @db.Decimal(14, 4)
  changePCT       Decimal? @db.Decimal(14, 4)
  change          Decimal? @db.Decimal(14, 4)
  quoteStatus     String?

  account          Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  asset            Asset            @relation(fields: [assetSymbol], references: [symbol])
  lots             Lot[]
  portfolio        Portfolio        @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  positionSnapshot PositionSnapshot @relation(fields: [positionSnapshotId], references: [id], onDelete: Cascade)

  @@unique([positionSnapshotId, externalId]) // Each position should only be on a snapshot once
  @@index([positionSnapshotId])
}

enum TaxGain {
  LONG
  SHORT
}

model Lot {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt
  positionId         BigInt?
  accountId          String   @db.Uuid
  portfolioId        String   @db.Uuid
  assetSymbol        String
  /// The unique id in the external system for the lot (positionLotId)
  externalId         String?
  excludeFromHarvest Int      @default(0)
  /// The file this lot was created from if it was from ingestion
  fileId             String?  @db.Uuid
  // The required fields (price paid per share and how many)
  /// The quantity of the asset owned in the lot 
  remainingQty       Decimal  @db.Decimal(14, 4)
  /// The price paid per asset unit in the lot (share price paid)
  price              Decimal  @db.Decimal(14, 4)
  acquiredDate       DateTime

  gainDay             Decimal? @db.Decimal(14, 4)
  gainDayPct          Decimal? @db.Decimal(14, 4)
  marketValue         Decimal? @db.Decimal(14, 4)
  costTotal           Decimal? @db.Decimal(14, 4)
  totalCostForGainPct Decimal? @db.Decimal(14, 4)
  gainTotal           Decimal? @db.Decimal(14, 4)
  originalQty         Decimal? @db.Decimal(14, 4)
  availableQty        Decimal? @db.Decimal(14, 4)
  orderNo             Decimal? @db.Decimal(14, 4)
  exchangeRate        Decimal? @db.Decimal(14, 4)
  settlementCurrency  String?  @default("USD")
  paymentCurrency     String?  @default("USD")
  adjPrice            Decimal? @db.Decimal(14, 4)
  commPerShare        Decimal? @db.Decimal(14, 4)
  feesPerShare        Decimal? @db.Decimal(14, 4)
  // TODO: Unkown etrade fields 
  lotSourceCode       Int?
  termCode            Int?
  legNo               Int?
  locationCode        Int?
  shortType           Int?

  file                    File?                    @relation(fields: [fileId], references: [id], onDelete: SetNull)
  asset                   Asset                    @relation(fields: [assetSymbol], references: [symbol])
  position                Position?                @relation(fields: [positionId], references: [id], onDelete: Cascade)
  account                 Account                  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  harvestTransactionItems HarvestTransactionItem[]
  portfolio               Portfolio                @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  LotChange               LotChange[]

  @@unique([positionId, externalId])
  @@index([accountId])
}

enum PortfolioRole {
