model AssetType {
  code        String      @id
  assetClass  AssetClass
  description String
  locale      AssetLocale

  assets Asset[]
}

model Asset {
  symbol            String  @id
  active            Boolean @default(true)
  plaid_security_id String? @unique

  // udpated daily from polygon
  lastPrice          Decimal  @default(0) @db.Decimal(14, 4)
  lastOpen           Decimal  @default(0) @db.Decimal(14, 4)
  lastClose          Decimal  @default(0) @db.Decimal(14, 4)
  lastLow            Decimal  @default(0) @db.Decimal(14, 4)
  lastHigh           Decimal  @default(0) @db.Decimal(14, 4)
  lastVolume         Decimal  @default(0) @db.Decimal(14, 4)
  lastVolumeWeighted Decimal  @default(0) @db.Decimal(14, 4)
  todaysChange       Decimal  @default(0) @db.Decimal(14, 4)
  todaysChangePerc   Decimal  @default(0) @db.Decimal(14, 4)
  lastUpdated        DateTime @default(now())

  iconUrl                     String?
  logoUrl                     String?
  description                 String?
  homepageUrl                 String?
  listDate                    DateTime?
  cik                         String?
  compositeFigi               String?
  currencyName                String?
  delistedDate                DateTime?
  locale                      AssetLocale @default(us)
  assetClass                  AssetClass  @default(UNKNOWN)
  type                        String      @default("Unknown")
  marketCap                   Decimal?    @db.Decimal(16, 0)
  name                        String?
  primaryExchange             String?
  shareClassSharesOutstanding Decimal?    @db.Decimal(16, 0)
  sicCode                     String?
  sicDescription              String?
  totalEmployees              Int?
  assetTypeCode               String?

  priceHourly             PriceHourly[]
  assetType               AssetType?               @relation(fields: [assetTypeCode], references: [code])
  priceHourlyVectors      PriceHourlyVector[]
  favoritedBy             User[]
  positions               Position[]
  vectorGraphs            VectorGraph[]
  transactions            Transaction[]
  lots                    Lot[]
  harvestTransactionItems HarvestTransactionItem[]
}

model PriceHourly {
  open                 Int // 4
  close                Int // 8
  high                 Int // 12
  low                  Int // 16
  assetSymbol          String // 20?
  numberOfTransactions Int? // 24
  startDate            DateTime // 32
  volumeWeightAverage  Int // 36
  volume               Int // 40 gbytes * 1 billion rows ~ 40 Gigs

  assset Asset @relation(fields: [assetSymbol], references: [symbol])

  @@id([assetSymbol, startDate])
}

// Vector Models ------------------------------------------------------------------------------------------------------------------------------

enum VectorWindow {
  MONTH_1
  MONTH_3
  MONTH_6
  YEAR_1
  YEAR_2
}

/// PriceHourlyVector is a % daily change going back # weeks from the start date for a given asset - up to 1000 days (~ > 3 months)
model PriceHourlyVector {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetSymbol String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  /// Asset this vector is for
  asset        Asset        @relation(fields: [assetSymbol], references: [symbol])
  /// The date that we start the vector from and go backwards in time to reach the total number of days
  startDate    DateTime
  /// The number of days (including weekends) that we want the vector to span
  vectorWindow VectorWindow

  /// @HideField({ output: true, input: true })
  vector       Unsupported("vector(1060)")?
  vectorGraphs VectorGraph[]

  @@unique([assetSymbol, startDate, vectorWindow])
}

// Plaid ------------------------------------------------------------------------------------------------------------------------------

// Graphs ------------------------------------------------------------------------------------------------------------------------------
enum Graph {
  /// Return percent over the length of days in hudredths of a percent
  RETURN_PCT_LINE
}

model VectorGraph {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  type                Graph
  priceHourlyVectorId String @db.Uuid
  assetSymbol         String
  data                Json[]

  asset             Asset             @relation(fields: [assetSymbol], references: [symbol])
  priceHourlyVector PriceHourlyVector @relation(fields: [priceHourlyVectorId], references: [id])

  // Only one type of graph per vector
  @@unique([assetSymbol, type, priceHourlyVectorId])
}

// Auth ------------------------------------------------------------------------------------------------------------------------------

/// The source of the auth connection
enum AuthSource {
  /// Access to the auth api to eventuially get access to the core api (https://api.etrade.com/oauth/request_token)
  ETRADE_REQUEST
  /// Access to the core api (https://api.etrade.com)
  ETRADE_ACCESS
  PLAID
  /// LOCAL Testing / System Generated
  LOCAL
}

enum AuthType {
  OAUTH_1
  PLAID_LINK
}

/// An authorized connection to some external system
model AuthConnection {
  /// Internal identifier
  id                           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// User this provider pertains to
  userId                       String
  /// The portfolio this provider belongs to
  portfolioId                  String     @db.Uuid
  /// When the model was created
  createdAt                    DateTime   @default(now())
  /// When the model was updated
  updatedAt                    DateTime   @default(now()) @updatedAt
  /// Source of the auth
  source                       AuthSource
  /// The type of auth
  type                         AuthType
  /// Used for etrade to store the url where the user can get their verifier code (valid for 5 minutes)
  verificationUrl              String?
  /// PLAID -> Plaid Item id, ETRADE -> random UUID since they dont have one
  externalId                   String     @unique
  /// Is the connection currently syncing
  isSyncing                    Boolean    @default(false)
  /// When were current authentication credentials generated with the provider
  authedAt                     DateTime   @default(now())
  /// When was the sync made
  syncedAt                     DateTime?
  /// When was the last transaction sync Plaid
  lastTransactionSyncedAtPlaid DateTime?

  // Oauth Fields -------
  /// @HideField({ output: true, input: true })
  token    String?
  /// @HideField({ output: true, input: true })
  secret   String?
  /// @HideField({ output: true, input: true })
  verifier String?

  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio           Portfolio             @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  accounts            Account[]
  lotTransactionBatch LotTransactionBatch[]

  @@unique([source, userId, portfolioId, externalId])
  @@index([portfolioId])
  @@index([externalId])
}

enum FileType {
  ETRADE_LOTS
}

model File {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gcpFilename String
  type        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  uploadedBy  String
  accountId   String   @db.Uuid
  displayName String
  fileType    FileType @default(ETRADE_LOTS)
  portfolioId String   @db.Uuid

  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  lots      Lot[]
  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

enum LogType {
  EXTERNAL_SYNC
  AUTH
  PLAID_WEBHOOK
  PLAID_TRX_MERGE
}

model Log {
  id             Int         @id @default(autoincrement())
  type           LogType
  createdAt      DateTime    @default(now())
  source         AuthSource?
  description    String?
  responseStatus Int?
  data           Json
  portfolioId    String      @db.Uuid

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, type])
}

