model PriceHourly {
  open                 Int // 4
  close                Int // 8
  high                 Int // 12
  low                  Int // 16
  assetSymbol          String // 20?
  numberOfTransactions Int? // 24
  startDate            DateTime // 32
  volumeWeightAverage  Int // 36
  volume               Int // 40 gbytes * 1 billion rows ~ 40 Gigs

  assset Asset @relation(fields: [assetSymbol], references: [symbol])

  @@id([assetSymbol, startDate])
}

// Vector Models ------------------------------------------------------------------------------------------------------------------------------

enum VectorWindow {
  MONTH_1
  MONTH_3
  MONTH_6
  YEAR_1
  YEAR_2
}

/// PriceHourlyVector is a % daily change going back # weeks from the start date for a given asset - up to 1000 days (~ > 3 months)
model PriceHourlyVector {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetSymbol String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  /// Asset this vector is for
  asset        Asset        @relation(fields: [assetSymbol], references: [symbol])
  /// The date that we start the vector from and go backwards in time to reach the total number of days
  startDate    DateTime
  /// The number of days (including weekends) that we want the vector to span
  vectorWindow VectorWindow

  /// @HideField({ output: true, input: true })
  vector       Unsupported("vector(1060)")?
  vectorGraphs VectorGraph[]

  @@unique([assetSymbol, startDate, vectorWindow])
}

// Plaid ------------------------------------------------------------------------------------------------------------------------------

// Graphs ------------------------------------------------------------------------------------------------------------------------------
enum Graph {
  /// Return percent over the length of days in hudredths of a percent
  RETURN_PCT_LINE
}

model VectorGraph {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  type                Graph
  priceHourlyVectorId String @db.Uuid
  assetSymbol         String
  data                Json[]

  asset             Asset             @relation(fields: [assetSymbol], references: [symbol])
  priceHourlyVector PriceHourlyVector @relation(fields: [priceHourlyVectorId], references: [id])

  // Only one type of graph per vector
  @@unique([assetSymbol, type, priceHourlyVectorId])
}

// Auth ------------------------------------------------------------------------------------------------------------------------------

/// The source of the auth connection
enum AuthSource {
  /// Access to the auth api to eventuially get access to the core api (https://api.etrade.com/oauth/request_token)
  ETRADE_REQUEST
  /// Access to the core api (https://api.etrade.com)
  ETRADE_ACCESS
  PLAID
  /// LOCAL Testing / System Generated
  LOCAL
}

enum AuthType {
  OAUTH_1
  PLAID_LINK
}

/// An authorized connection to Plaid (one ot one to a plaid Link/item)
model AuthConnection {
  /// Internal identifier
  id                           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// User this provider pertains to
  userId                       String
  /// The portfolio this provider belongs to
  portfolioId                  String     @db.Uuid
  /// When the model was created
  createdAt                    DateTime   @default(now())
  /// When the model was updated
  updatedAt                    DateTime   @default(now()) @updatedAt
  /// Source of the auth
  source                       AuthSource
  /// The type of auth
  type                         AuthType
  /// Used for etrade to store the url where the user can get their verifier code (valid for 5 minutes)
  verificationUrl              String?
  /// PLAID -> Plaid Item id, ETRADE -> random UUID since they dont have one
  externalId                   String     @unique
  /// Is the connection currently syncing
  isSyncing                    Boolean    @default(false)
  /// When were current authentication credentials generated with the provider
  authedAt                     DateTime   @default(now())
  /// When was the sync made
  syncedAt                     DateTime?
  /// When was the last transaction sync Plaid
  lastTransactionSyncedAtPlaid DateTime?
  /// Plaid institution id (from plaid API)
  plaidInstitutionId           String
  /// Plaid institution id (from our database)
  portfolioConnectId           String     @unique @db.Uuid

  // Oauth Fields -------
  /// @HideField({ output: true, input: true })
  token    String?
  /// @HideField({ output: true, input: true })
  secret   String?
  /// @HideField({ output: true, input: true })
  verifier String?

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio        Portfolio          @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  accounts         Account[]
  positionSnapshot PositionSnapshot[]
  portfolioConnect PortfolioConnect   @relation(fields: [portfolioConnectId], references: [id], onDelete: Cascade)
  plaidInstitution PlaidInstitution   @relation(fields: [plaidInstitutionId], references: [id], onDelete: Cascade)

  /// Only one link per user per portfolio per source (importantly a user can only have 1 plaid link per portfolio in a given institution)
  /// We must enforce this else transactions lots etc. will be duplicated in portfolios from plaid (trx ids change depending on the plaid link)
  /// Essentially unique institution per user per portfolio
  @@unique([source, userId, portfolioId, plaidInstitutionId])
  @@index([portfolioId, plaidInstitutionId])
  @@index([portfolioId])
  @@index([externalId])
}

/// Plaid institution data synced nightly from Plaid API
model PlaidInstitution {
  id               String             @id
  name             String
  countryCode      String[] // Array of country codes
  url              String?
  primaryColor     String?
  logo             String? // URL or base64 encoded
  oauth            Boolean            @default(false)
  products         String[] // Array of product names
  routingNumbers   String[]           @default([])
  dtcNumbers       String[]           @default([])
  status           Json               @db.JsonB // Nested status data
  raw              Json?              @db.JsonB // Complete API response (optional)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @default(now()) @updatedAt
  lastSyncedAt     DateTime           @default(now())
  portfolioConnect PortfolioConnect[]
  authConnection   AuthConnection[]

  @@index([name])
  @@index([lastSyncedAt])
}

model File {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gcpFilename String
  type        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  uploadedBy  String
  accountId   String   @db.Uuid
  displayName String
  portfolioId String   @db.Uuid

  account       Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  lots          Lot[]
  portfolio     Portfolio       @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  LotUploadFile LotUploadFile[]
}

enum LotUploadFileType {
  ETRADE_LOTS
  SCHWAB_LOTS
  SCHWAB_POSITIONS
}

model LotUpload {
  id                          String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @default(now()) @updatedAt
  portfolioId                 String                      @db.Uuid
  accountId                   String                      @db.Uuid
  applied                     Boolean                     @default(false)
  /// If an account is skipped from onboarding, we can use the positions to generate lots
  usePositionsAsLots          Boolean                     @default(false)
  supportedAccountLotProvider SupportedAccountLotProvider

  portfolio     Portfolio       @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  account       Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  LotUploadFile LotUploadFile[]
}

model LotUploadFile {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @default(now()) @updatedAt
  portfolioId String            @db.Uuid
  accountId   String            @db.Uuid
  /// Optional - we use this as validation that a file must be attached before the LotUplaod can be applied
  fileId      String?           @db.Uuid
  type        LotUploadFileType
  lotUploadId String            @db.Uuid
  assetSymbol String?

  file      File?     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  lotUpload LotUpload @relation(fields: [lotUploadId], references: [id], onDelete: Cascade)
  asset     Asset?    @relation(fields: [assetSymbol], references: [symbol], onDelete: Restrict)
}

enum MergeErrorType {
  PLAID_MULTI_LOT_SOLUTION
  PLAID_NO_SOLUTION
  PLAID_MERGE_TIMEOUT
  UNKNOWN
}

model MergeError {
  id                     String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type                   MergeErrorType
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @default(now()) @updatedAt
  portfolioId            String         @db.Uuid
  assetSymbol            String
  targetValue            Decimal?       @db.Decimal(14, 4)
  targetQuantity         Decimal?       @db.Decimal(14, 4)
  lotsData               Json           @db.JsonB
  lotChangeSetAlgoParams Json?          @db.JsonB
  resolved               Boolean        @default(false)
  logId                  BigInt?
  accountId              String         @db.Uuid

  portfolio  Portfolio    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset      Asset        @relation(fields: [assetSymbol], references: [symbol], onDelete: Restrict)
  log        Log?         @relation(fields: [logId], references: [id], onDelete: Cascade)
  account    Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  AssetMerge AssetMerge[]

  @@index([createdAt(sort: Desc)])
}

enum NotificationLevel {
  INFO
  WARNING
  ERROR
}

model Notification {
  id          Int               @id @default(autoincrement())
  createdAt   DateTime          @default(now())
  title       String
  description String?
  body        String?
  acked       Boolean           @default(false)
  portfolioId String            @db.Uuid
  accountId   String?           @db.Uuid
  level       NotificationLevel @default(INFO)

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  account   Account?  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([portfolioId, acked])
}

enum LogType {
  EXTERNAL_SYNC
  AUTH
  PLAID_WEBHOOK
  PLAID_TRX_MERGE
  PLAID_TRX_MERGE_SUCCESS
  PLAID_TRX_MERGE_ERROR
  SUBSET_HYBRID_CALCULATION
}

model Log {
  id             BigInt      @id @default(autoincrement())
  type           LogType
  createdAt      DateTime    @default(now())
  source         AuthSource?
  description    String?
  responseStatus Int?
  data           Json
  portfolioId    String      @db.Uuid

  portfolio  Portfolio    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  lotMerge   AssetMerge[]
  mergeError MergeError[]

  @@index([portfolioId, type])
}

/// Basically one to one with AccountRealizedPAndLHistory (just rolled up)
model PortfolioBalanceSnapshot {
  id          BigInt   @id @default(autoincrement())
  createdAt   DateTime @default(now())
  portfolioId String   @db.Uuid

  // Fields controlled by the plaid/investments/holdings/get https://plaid.com/docs/api/products/investments/#investmentsholdingsget
  current             Decimal   @default(0) @db.Decimal(14, 4)
  available           Decimal   @default(0) @db.Decimal(14, 4)
  lastUpdatedDatetime DateTime?

  // Fields we track (1 to 1 with ProfitAndLossType) using plaid/investments/transactions/get https://plaid.com/docs/api/products/investments/#investmentstransactionsget
  shortTermCapitalGain Decimal @default(0) @db.Decimal(14, 4)
  longTermCapitalGain  Decimal @default(0) @db.Decimal(14, 4)
  dividend             Decimal @default(0) @db.Decimal(14, 4)
  qualifiedDividend    Decimal @default(0) @db.Decimal(14, 4)
  nonQualifiedDividend Decimal @default(0) @db.Decimal(14, 4)
  dividendReinvestment Decimal @default(0) @db.Decimal(14, 4)
  interest             Decimal @default(0) @db.Decimal(14, 4)
  interestReinvestment Decimal @default(0) @db.Decimal(14, 4)
  distribution         Decimal @default(0) @db.Decimal(14, 4)
  accountFee           Decimal @default(0) @db.Decimal(14, 4)
  managementFee        Decimal @default(0) @db.Decimal(14, 4)
  fundFee              Decimal @default(0) @db.Decimal(14, 4)
  taxWithheld          Decimal @default(0) @db.Decimal(14, 4)
  nonResidentTax       Decimal @default(0) @db.Decimal(14, 4)
  deposit              Decimal @default(0) @db.Decimal(14, 4)
  withdrawal           Decimal @default(0) @db.Decimal(14, 4)
  contribution         Decimal @default(0) @db.Decimal(14, 4)
  returnOfPrincipal    Decimal @default(0) @db.Decimal(14, 4)
  loanPayment          Decimal @default(0) @db.Decimal(14, 4)
  marginExpense        Decimal @default(0) @db.Decimal(14, 4)
  stockDistribution    Decimal @default(0) @db.Decimal(14, 4)
  unqualifiedGain      Decimal @default(0) @db.Decimal(14, 4)

  // Derived info we roll up for efficiency
  unrealizedProfit Decimal @default(0) @db.Decimal(14, 4)
  unrealizedLoss   Decimal @default(0) @db.Decimal(14, 4)

  portfolio                                  Portfolio                                    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  PositionSnapshotOnPortfolioBalanceSnapshot PositionSnapshotOnPortfolioBalanceSnapshot[]

  @@index([portfolioId, createdAt(desc)])
}

model PositionSnapshotOnPortfolioBalanceSnapshot {
  positionSnapshotId         String @db.Uuid
  portfolioBalanceSnapshotId BigInt

  positionSnapshot         PositionSnapshot         @relation(fields: [positionSnapshotId], references: [id], onDelete: Cascade)
  portfolioBalanceSnapshot PortfolioBalanceSnapshot @relation(fields: [portfolioBalanceSnapshotId], references: [id], onDelete: Cascade)

  @@id([positionSnapshotId, portfolioBalanceSnapshotId])
}

