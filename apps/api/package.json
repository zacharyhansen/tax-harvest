{
  "name": "api",
  "type": "module",
  "version": "1.0.0",
  "description": "Super cool API",
  "author": "Zachary Hansen",
  "license": "UNLICENSED",
  "homepage": "https://github.com/zacharyhansen/tax-harvest#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zacharyhansen/tax-harvest.git"
  },
  "bugs": {
    "url": "https://github.com/zacharyhansen/tax-harvest/issues"
  },
  "keywords": [
    "typescript",
    "nestjs",
    "template"
  ],
  "main": "dist/main.js",
  "engines": {
    "node": ">=22.x",
    "pnpm": ">=9.x"
  },
  "scripts": {
    "build": "npx prisma generate && pnpm codegen:kysely && node --run build:clean && nest build --path tsconfig.prod.json",
    "start": "node dist/main.js",
    "dev": "nest start --watch --debug=0.0.0.0:9229",
    "test": "concurrently 'pnpm test:unit' 'pnpm test:e2e'",
    "test:unit": "vitest run --coverage --config vitest.config.unit.ts",
    "test:unit:watch": "vitest --watch --config vitest.config.unit.ts",
    "test:e2e": "vitest run --coverage --config ./vitest.config.e2e.ts",
    "test:performance": "k6 run tests/performance/contexts/users/get-users.mjs",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "build:clean": "rimraf dist; exit 0",
    "codegen:snaplet": "npx @snaplet/seed sync",
    "codegen:kysely": "npx kysely-codegen --out-file ./src/database/db.d.ts",
    "codegen": "npx prisma generate && pnpm codegen:kysely && pnpm codegen:snaplet",
    "migrate": "prisma migrate dev",
    "migrate:reset": "prisma migrate reset",
    "sync": "node dist/command/post-migrate.js",
    "postmigrate": "pnpm codegen",
    "migrate:create": "prisma migrate dev --create-only --name",
    "seed": "prisma db seed",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma"
  },
  "@snaplet/seed": {
    "config": "seed.client.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed/seed.ts"
  },
  "peerDependencies": {
    "@antfu/eslint-config": "^4.12.0",
    "@vitest/coverage-v8": "^3.1.2",
    "eslint": "^9.24.0",
    "typescript": "5.4.2",
    "vitest": "^3.1.2",
    "vitest-mock-extended": "^3.1.0",
    "zod": "^3.24.3"
  },
  "dependencies": {
    "@apollo/server": "4.10.4",
    "@as-integrations/fastify": "^2.1.1",
    "@clerk/backend": "^1.23.11",
    "@clerk/clerk-sdk-node": "^5.0.15",
    "@fastify/static": "^8.1.0",
    "@google-cloud/secret-manager": "^5.6.0",
    "@google-cloud/storage": "^7.14.0",
    "@nestjs/apollo": "^12.1.0",
    "@nestjs/cache-manager": "^3.0.0",
    "@nestjs/common": "11.0.7",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "11.0.7",
    "@nestjs/graphql": "^12.1.0",
    "@nestjs/platform-fastify": "11.0.7",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@polygon.io/client-js": "^7.3.2",
    "@prisma/client": "5.20.0",
    "apollo-server-errors": "^3.3.1",
    "cache-manager": "^6.4.0",
    "class-transformer": "^0.5.1",
    "csv-parse": "^5.5.3",
    "decimal.js": "^10.5.0",
    "fastify": "^5.3.0",
    "fastify-swagger": "^5.2.0",
    "graphql": "^16.8.1",
    "graphql-fields": "^2.0.3",
    "graphql-parse-resolve-info": "4.13.0",
    "graphql-type-json": "^0.3.2",
    "kysely": "^0.27.4",
    "oauth": "^0.10.0",
    "pg": "^8.13.0",
    "pgvector": "^0.1.7",
    "plaid": "^29.0.0",
    "prisma-graphql-type-decimal": "^3.0.1",
    "puppeteer": "^23.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stripe": "^16.2.0",
    "superjson": "^2.2.2",
    "svix": "^1.40.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.24.3",
    "@swc/core-linux-arm64-musl": "^1.7.42",
    "@swc/core-linux-x64-gnu": "^1.7.42",
    "@swc/core-linux-x64-musl": "^1.7.42"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "@nestjs/cli": "11.0.7",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "11.1.0",
    "@snaplet/copycat": "^5.1.0",
    "@snaplet/seed": "^0.98.0",
    "@swc/cli": "^0.4.0",
    "@swc/core": "^1.7.42",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.8.7",
    "@types/oauth": "^0.9.6",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "adapter-pg": "link:@snaplet/seed/adapter-pg",
    "concurrently": "^9.0.1",
    "dotenv-cli": "^7.4.2",
    "fs-extra": "^11.2.0",
    "jest": "^29.7.0",
    "kysely-codegen": "^0.16.8",
    "nock": "^13.5.5",
    "prisma": "^5.20.0",
    "prisma-nestjs-graphql": "20.0.3",
    "rimraf": "^6.0.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "unplugin-swc": "^1.5.1",
    "vite": "^5.4.10"
  }
}
