{
	"$schema": "https://biomejs.dev/schemas/2.1.2/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!**/dist",
			"!**/*.css",
			"!**/build",
			"!**/.next",
			"!**/node_modules",
			"!**/coverage",
			"!**/.turbo",
			"!**/.vercel",
			"!**/out",
			"!**/generated",
			"!**/*.tsbuildinfo",
			"!**/storybook-static",
			"!**/.nyc_output"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedVariables": "error"
			},
			"suspicious": {
				"noExplicitAny": "error"
			},
			"a11y": {
				"recommended": true
			},
			"complexity": {
				"recommended": true
			},
			"performance": {
				"recommended": true
			},
			"security": {
				"recommended": true
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		},
		"parser": {
			"unsafeParameterDecoratorsEnabled": true
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"overrides": [
		{
			"includes": ["apps/api/src/**/*.ts"],
			"javascript": {
				"parser": {
					"unsafeParameterDecoratorsEnabled": true
				}
			},
			"linter": {
				"rules": {
					"complexity": {
						"noUselessConstructor": "off"
					},
					"style": {
						"useImportType": "off"
					}
				}
			}
		}
	]
}
